Notebook[{
Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"**", "\[IndentingNewLine]", "A1"}], "\[IndentingNewLine]", 
   "***)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"adamSolve", "[", 
     RowBox[{"equations_", ",", "variables_", ",", "initialGuess_", ",", 
      RowBox[{"\[Alpha]_", ":", "0.001"}], ",", 
      RowBox[{"\[Beta]1_", ":", "0.9"}], ",", 
      RowBox[{"\[Beta]2_", ":", "0.999"}], ",", 
      RowBox[{"\[CurlyEpsilon]_", ":", 
       RowBox[{"10", "^", 
        RowBox[{"-", "8"}]}]}], ",", 
      RowBox[{"maxIterations_", ":", "10000"}], ",", 
      RowBox[{"tolerance_", ":", 
       RowBox[{"10", "^", 
        RowBox[{"-", "6"}]}]}]}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"n", "=", 
         RowBox[{"Length", "[", "variables", "]"}]}], ",", 
        RowBox[{"numEq", "=", 
         RowBox[{"Length", "[", "equations", "]"}]}], ",", 
        RowBox[{"\[Theta]", "=", "initialGuess"}], ",", 
        RowBox[{"m1", "=", 
         RowBox[{"ConstantArray", "[", 
          RowBox[{"0", ",", 
           RowBox[{"Length", "[", "variables", "]"}]}], "]"}]}], ",", 
        RowBox[{"v1", "=", 
         RowBox[{"ConstantArray", "[", 
          RowBox[{"0", ",", 
           RowBox[{"Length", "[", "variables", "]"}]}], "]"}]}], ",", "mHat", 
        ",", "vHat", ",", "grad", ",", "error", ",", "t", ",", "eqIndex"}], 
       "}"}], ",", 
      RowBox[{
       RowBox[{"For", "[", 
        RowBox[{
         RowBox[{"t", "=", "1"}], ",", 
         RowBox[{"t", "<=", "maxIterations"}], ",", 
         RowBox[{"t", "++"}], ",", 
         RowBox[{"(*", 
          RowBox[{"Choose", " ", "a", " ", "random", " ", "equation"}], 
          "*)"}], 
         RowBox[{
          RowBox[{"eqIndex", "=", 
           RowBox[{"RandomInteger", "[", 
            RowBox[{"{", 
             RowBox[{"1", ",", "numEq"}], "}"}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
           "Compute", " ", "gradient", " ", "of", " ", "the", " ", "squared", 
            " ", "error", " ", "for", " ", "the", " ", "chosen", " ", 
            "equation"}], "*)"}], 
          RowBox[{"grad", "=", 
           RowBox[{"D", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"equations", "[", 
               RowBox[{"[", "eqIndex", "]"}], "]"}], "^", "2"}], ",", 
             RowBox[{"{", "variables", "}"}]}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"grad", "=", 
           RowBox[{"grad", "/.", " ", 
            RowBox[{"Thread", "[", 
             RowBox[{"variables", "->", "\[Theta]"}], "]"}]}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
           "Update", " ", "biased", " ", "first", " ", "moment", " ", 
            "estimate"}], "*)"}], 
          RowBox[{"m1", "=", 
           RowBox[{
            RowBox[{"\[Beta]1", "*", "m1"}], "+", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"1", "-", "\[Beta]1"}], ")"}], "*", "grad"}]}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
           "Update", " ", "biased", " ", "second", " ", "raw", " ", "moment", 
            " ", "estimate"}], "*)"}], 
          RowBox[{"v1", "=", 
           RowBox[{
            RowBox[{"\[Beta]2", "*", "v1"}], "+", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"1", "-", "\[Beta]2"}], ")"}], "*", 
             RowBox[{"grad", "^", "2"}]}]}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
            RowBox[{"Compute", " ", "bias"}], "-", 
            RowBox[{
            "corrected", " ", "first", " ", "moment", " ", "estimate"}]}], 
           "*)"}], 
          RowBox[{"mHat", "=", 
           RowBox[{"m1", "/", 
            RowBox[{"(", 
             RowBox[{"1", "-", 
              RowBox[{"\[Beta]1", "^", "t"}]}], ")"}]}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
            RowBox[{"Compute", " ", "bias"}], "-", 
            RowBox[{
            "corrected", " ", "second", " ", "raw", " ", "moment", " ", 
             "estimate"}]}], "*)"}], 
          RowBox[{"vHat", "=", 
           RowBox[{"v1", "/", 
            RowBox[{"(", 
             RowBox[{"1", "-", 
              RowBox[{"\[Beta]2", "^", "t"}]}], ")"}]}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{"Update", " ", "parameters"}], "*)"}], 
          RowBox[{"\[Theta]", "=", 
           RowBox[{"\[Theta]", "-", 
            RowBox[{"\[Alpha]", "*", 
             RowBox[{"mHat", "/", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"Sqrt", "[", "vHat", "]"}], "+", "\[CurlyEpsilon]"}], 
               ")"}]}]}]}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{"Compute", " ", "total", " ", "error"}], "*)"}], 
          RowBox[{"error", "=", 
           RowBox[{"Total", "[", 
            RowBox[{
             RowBox[{"equations", "^", "2"}], "/.", " ", 
             RowBox[{"Thread", "[", 
              RowBox[{"variables", "->", "\[Theta]"}], "]"}]}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{"Check", " ", "for", " ", "convergence"}], "*)"}], 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"error", "<", "tolerance"}], ",", 
            RowBox[{"Return", "[", 
             RowBox[{"Thread", "[", 
              RowBox[{"variables", "->", "\[Theta]"}], "]"}], "]"}]}], 
           "]"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"Return", " ", "result"}], "*)"}], 
       RowBox[{"Thread", "[", 
        RowBox[{"variables", "->", "\[Theta]"}], "]"}]}]}], "]"}]}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"findMultipleSolutions", "[", 
     RowBox[{"equations_", ",", "variables_", ",", 
      RowBox[{"numSolutions_", ":", "6"}], ",", 
      RowBox[{"numAttempts_", ":", "100"}], ",", 
      RowBox[{"\[Alpha]_", ":", "0.001"}], ",", 
      RowBox[{"\[Beta]1_", ":", "0.9"}], ",", 
      RowBox[{"\[Beta]2_", ":", "0.999"}], ",", 
      RowBox[{"\[CurlyEpsilon]_", ":", 
       RowBox[{"10", "^", 
        RowBox[{"-", "8"}]}]}], ",", 
      RowBox[{"maxIterations_", ":", "20000"}], ",", 
      RowBox[{"tolerance_", ":", 
       RowBox[{"10", "^", 
        RowBox[{"-", "6"}]}]}]}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"solutions", "=", 
         RowBox[{"{", "}"}]}], ",", "attempt", ",", "newSolution", ",", 
        "isNewSolution", ",", "initialGuess", ",", "solutionValues"}], "}"}], 
      ",", 
      RowBox[{
       RowBox[{"For", "[", 
        RowBox[{
         RowBox[{"attempt", "=", "1"}], ",", 
         RowBox[{
          RowBox[{"attempt", "<=", "numAttempts"}], "&&", 
          RowBox[{
           RowBox[{"Length", "[", "solutions", "]"}], "<", "numSolutions"}]}],
          ",", 
         RowBox[{"attempt", "++"}], ",", 
         RowBox[{"(*", 
          RowBox[{
          "Generate", " ", "a", " ", "random", " ", "initial", " ", "guess"}],
           "*)"}], 
         RowBox[{
          RowBox[{"initialGuess", "=", 
           RowBox[{"{", 
            RowBox[{
            "0.1", ",", " ", "0.045", ",", " ", "0.075", ",", " ", "0.155", 
             ",", " ", "50", ",", " ", "25"}], "}"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{"Run", " ", "Adam", " ", "optimizer"}], "*)"}], 
          RowBox[{"newSolution", "=", 
           RowBox[{"adamSolve", "[", 
            RowBox[{
            "equations", ",", "variables", ",", "initialGuess", ",", 
             "\[Alpha]", ",", "\[Beta]1", ",", "\[Beta]2", ",", 
             "\[CurlyEpsilon]", ",", "maxIterations", ",", "tolerance"}], 
            "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
           "Extract", " ", "numerical", " ", "values", " ", "from", " ", 
            "the", " ", "solution"}], "*)"}], 
          RowBox[{"solutionValues", "=", 
           RowBox[{"variables", "/.", " ", "newSolution"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
           "Check", " ", "if", " ", "this", " ", "is", " ", "a", " ", "new", 
            " ", "solution"}], "*)"}], 
          RowBox[{"isNewSolution", "=", 
           RowBox[{"And", "@@", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{"Norm", "[", 
                 RowBox[{"solutionValues", "-", 
                  RowBox[{"(", 
                   RowBox[{"variables", "/.", " ", "#"}], ")"}]}], "]"}], ">",
                 "tolerance"}], "&"}], "/@", "solutions"}], ")"}]}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
            RowBox[{"If", " ", 
             RowBox[{"it", "'"}], "s", " ", "a", " ", "new", " ", 
             "solution"}], ",", 
            RowBox[{"add", " ", "it", " ", "to", " ", "the", " ", "list"}]}], 
           "*)"}], 
          RowBox[{"If", "[", 
           RowBox[{"isNewSolution", ",", 
            RowBox[{
             RowBox[{"AppendTo", "[", 
              RowBox[{"solutions", ",", "newSolution"}], "]"}], ";"}]}], 
           "]"}], ";"}]}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"Return", " ", "all", " ", "found", " ", "solutions"}], 
        "*)"}], "solutions"}]}], "]"}]}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"**", "\[IndentingNewLine]", 
