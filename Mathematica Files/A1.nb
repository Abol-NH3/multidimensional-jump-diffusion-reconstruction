    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"collected", ",", "variables"}], "}"}], ",", 
      RowBox[{
       RowBox[{"variables", "=", 
        RowBox[{"DeleteDuplicates", "@", 
         RowBox[{"Flatten", "[", 
          RowBox[{"monomials", "/.", " ", 
           RowBox[{"{", 
            RowBox[{"Times", "->", "List"}], "}"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Flatten", "[", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"collected", "=", 
            RowBox[{"Collect", "[", 
