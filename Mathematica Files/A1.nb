              RowBox[{"MExprs", "[", 
               RowBox[{"[", "i", "]"}], "]"}], ",", "monomials"}], "]"}]}], 
           ";", "\[IndentingNewLine]", 
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{"If", "[", 
