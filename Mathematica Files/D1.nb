          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
           "Update", " ", "biased", " ", "first", " ", "moment", " ", 
            "estimate"}], "*)"}], 
          RowBox[{"m1", "=", 
           RowBox[{
            RowBox[{"\[Beta]1", "*", "m1"}], "+", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"1", "-", "\[Beta]1"}], ")"}], "*", "grad"}]}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
           "Update", " ", "biased", " ", "second", " ", "raw", " ", "moment", 
