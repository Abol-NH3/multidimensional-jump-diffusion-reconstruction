             RowBox[{"(", 
              RowBox[{"1", "-", "\[Beta]2"}], ")"}], "*", 
             RowBox[{"grad", "^", "2"}]}]}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
            RowBox[{"Compute", " ", "bias"}], "-", 
            RowBox[{
            "corrected", " ", "first", " ", "moment", " ", "estimate"}]}], 
           "*)"}], 
          RowBox[{"mHat", "=", 
           RowBox[{"m1", "/", 
            RowBox[{"(", 
             RowBox[{"1", "-", 
              RowBox[{"\[Beta]1", "^", "t"}]}], ")"}]}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
