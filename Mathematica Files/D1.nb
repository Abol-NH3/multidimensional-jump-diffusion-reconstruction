      RowBox[{"tolerance_", ":", 
       RowBox[{"10", "^", 
        RowBox[{"-", "6"}]}]}]}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
