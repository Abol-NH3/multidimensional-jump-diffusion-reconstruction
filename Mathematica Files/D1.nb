Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"**", "\[IndentingNewLine]", "D1"}], "\[IndentingNewLine]", 
   "***)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"adamSolve", "[", 
     RowBox[{"equations_", ",", "variables_", ",", "initialGuess_", ",", 
