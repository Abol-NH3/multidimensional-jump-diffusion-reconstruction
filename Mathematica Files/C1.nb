          RowBox[{"\[Theta]", "=", 
           RowBox[{"\[Theta]", "-", 
            RowBox[{"\[Alpha]", "*", 
             RowBox[{"mHat", "/", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"Sqrt", "[", "vHat", "]"}], "+", "\[CurlyEpsilon]"}], 
               ")"}]}]}]}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{"Compute", " ", "total", " ", "error"}], "*)"}], 
          RowBox[{"error", "=", 
           RowBox[{"Total", "[", 
            RowBox[{
             RowBox[{"equations", "^", "2"}], "/.", " ", 
             RowBox[{"Thread", "[", 
              RowBox[{"variables", "->", "\[Theta]"}], "]"}]}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{"Check", " ", "for", " ", "convergence"}], "*)"}], 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"error", "<", "tolerance"}], ",", 
            RowBox[{"Return", "[", 
             RowBox[{"Thread", "[", 
              RowBox[{"variables", "->", "\[Theta]"}], "]"}], "]"}]}], 
           "]"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"Return", " ", "result"}], "*)"}], 
       RowBox[{"Thread", "[", 
        RowBox[{"variables", "->", "\[Theta]"}], "]"}]}]}], "]"}]}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"findMultipleSolutions", "[", 
     RowBox[{"equations_", ",", "variables_", ",", 
      RowBox[{"numSolutions_", ":", "6"}], ",", 
      RowBox[{"numAttempts_", ":", "100"}], ",", 
      RowBox[{"\[Alpha]_", ":", "0.001"}], ",", 
      RowBox[{"\[Beta]1_", ":", "0.9"}], ",", 
