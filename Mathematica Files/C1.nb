                 "tolerance"}], "&"}], "/@", "solutions"}], ")"}]}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
            RowBox[{"If", " ", 
             RowBox[{"it", "'"}], "s", " ", "a", " ", "new", " ", 
             "solution"}], ",", 
            RowBox[{"add", " ", "it", " ", "to", " ", "the", " ", "list"}]}], 
           "*)"}], 
          RowBox[{"If", "[", 
