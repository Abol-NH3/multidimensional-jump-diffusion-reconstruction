         RowBox[{
          RowBox[{"attempt", "<=", "numAttempts"}], "&&", 
          RowBox[{
           RowBox[{"Length", "[", "solutions", "]"}], "<", "numSolutions"}]}],
          ",", 
         RowBox[{"attempt", "++"}], ",", 
         RowBox[{"(*", 
          RowBox[{
          "Generate", " ", "a", " ", "random", " ", "initial", " ", "guess"}],
           "*)"}], 
         RowBox[{
          RowBox[{"initialGuess", "=", 
           RowBox[{"{", 
            RowBox[{
            "0.1", ",", " ", "0.045", ",", " ", "0.075", ",", " ", "0.155", 
             ",", " ", "50", ",", " ", "25"}], "}"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{"Run", " ", "Adam", " ", "optimizer"}], "*)"}], 
          RowBox[{"newSolution", "=", 
           RowBox[{"adamSolve", "[", 
            RowBox[{
            "equations", ",", "variables", ",", "initialGuess", ",", 
             "\[Alpha]", ",", "\[Beta]1", ",", "\[Beta]2", ",", 
             "\[CurlyEpsilon]", ",", "maxIterations", ",", "tolerance"}], 
            "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
           "Extract", " ", "numerical", " ", "values", " ", "from", " ", 
            "the", " ", "solution"}], "*)"}], 
          RowBox[{"solutionValues", "=", 
           RowBox[{"variables", "/.", " ", "newSolution"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
           "Check", " ", "if", " ", "this", " ", "is", " ", "a", " ", "new", 
