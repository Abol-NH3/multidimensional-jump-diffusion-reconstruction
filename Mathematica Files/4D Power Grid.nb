Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"**", "\[IndentingNewLine]", "Power"}], " ", "Grid"}], 
   "\[IndentingNewLine]", "***)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"adamSolve", "[", 
     RowBox[{"equations_", ",", "variables_", ",", "initialGuess_", ",", 
      RowBox[{"\[Alpha]_", ":", "0.001"}], ",", 
      RowBox[{"\[Beta]1_", ":", "0.9"}], ",", 
      RowBox[{"\[Beta]2_", ":", "0.999"}], ",", 
      RowBox[{"\[CurlyEpsilon]_", ":", 
       RowBox[{"10", "^", 
        RowBox[{"-", "8"}]}]}], ",", 
      RowBox[{"maxIterations_", ":", "10000"}], ",", 
      RowBox[{"tolerance_", ":", 
       RowBox[{"10", "^", 
        RowBox[{"-", "6"}]}]}]}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"n", "=", 
         RowBox[{"Length", "[", "variables", "]"}]}], ",", 
        RowBox[{"numEq", "=", 
         RowBox[{"Length", "[", "equations", "]"}]}], ",", 
        RowBox[{"\[Theta]", "=", "initialGuess"}], ",", 
        RowBox[{"m1", "=", 
         RowBox[{"ConstantArray", "[", 
          RowBox[{"0", ",", 
           RowBox[{"Length", "[", "variables", "]"}]}], "]"}]}], ",", 
        RowBox[{"v1", "=", 
         RowBox[{"ConstantArray", "[", 
          RowBox[{"0", ",", 
           RowBox[{"Length", "[", "variables", "]"}]}], "]"}]}], ",", "mHat", 
        ",", "vHat", ",", "grad", ",", "error", ",", "t", ",", "eqIndex"}], 
       "}"}], ",", 
      RowBox[{
       RowBox[{"For", "[", 
        RowBox[{
         RowBox[{"t", "=", "1"}], ",", 
         RowBox[{"t", "<=", "maxIterations"}], ",", 
         RowBox[{"t", "++"}], ",", 
         RowBox[{"(*", 
          RowBox[{"Choose", " ", "a", " ", "random", " ", "equation"}], 
          "*)"}], 
         RowBox[{
          RowBox[{"eqIndex", "=", 
           RowBox[{"RandomInteger", "[", 
            RowBox[{"{", 
             RowBox[{"1", ",", "numEq"}], "}"}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
           "Compute", " ", "gradient", " ", "of", " ", "the", " ", "squared", 
            " ", "error", " ", "for", " ", "the", " ", "chosen", " ", 
            "equation"}], "*)"}], 
          RowBox[{"grad", "=", 
           RowBox[{"D", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"equations", "[", 
               RowBox[{"[", "eqIndex", "]"}], "]"}], "^", "2"}], ",", 
             RowBox[{"{", "variables", "}"}]}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"grad", "=", 
           RowBox[{"grad", "/.", " ", 
            RowBox[{"Thread", "[", 
             RowBox[{"variables", "->", "\[Theta]"}], "]"}]}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
           "Update", " ", "biased", " ", "first", " ", "moment", " ", 
            "estimate"}], "*)"}], 
          RowBox[{"m1", "=", 
           RowBox[{
            RowBox[{"\[Beta]1", "*", "m1"}], "+", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"1", "-", "\[Beta]1"}], ")"}], "*", "grad"}]}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
           "Update", " ", "biased", " ", "second", " ", "raw", " ", "moment", 
            " ", "estimate"}], "*)"}], 
          RowBox[{"v1", "=", 
           RowBox[{
            RowBox[{"\[Beta]2", "*", "v1"}], "+", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"1", "-", "\[Beta]2"}], ")"}], "*", 
             RowBox[{"grad", "^", "2"}]}]}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
            RowBox[{"Compute", " ", "bias"}], "-", 
            RowBox[{
            "corrected", " ", "first", " ", "moment", " ", "estimate"}]}], 
           "*)"}], 
          RowBox[{"mHat", "=", 
           RowBox[{"m1", "/", 
            RowBox[{"(", 
             RowBox[{"1", "-", 
              RowBox[{"\[Beta]1", "^", "t"}]}], ")"}]}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
