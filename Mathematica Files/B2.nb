         RowBox[{"t", "<=", "maxIterations"}], ",", 
         RowBox[{"t", "++"}], ",", 
         RowBox[{"(*", 
          RowBox[{"Choose", " ", "a", " ", "random", " ", "equation"}], 
          "*)"}], 
         RowBox[{
          RowBox[{"eqIndex", "=", 
           RowBox[{"RandomInteger", "[", 
            RowBox[{"{", 
             RowBox[{"1", ",", "numEq"}], "}"}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
           "Compute", " ", "gradient", " ", "of", " ", "the", " ", "squared", 
            " ", "error", " ", "for", " ", "the", " ", "chosen", " ", 
            "equation"}], "*)"}], 
          RowBox[{"grad", "=", 
           RowBox[{"D", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"equations", "[", 
