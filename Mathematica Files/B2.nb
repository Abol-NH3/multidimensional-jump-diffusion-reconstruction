             "\[Alpha]", ",", "\[Beta]1", ",", "\[Beta]2", ",", 
             "\[CurlyEpsilon]", ",", "maxIterations", ",", "tolerance"}], 
            "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"(*", 
