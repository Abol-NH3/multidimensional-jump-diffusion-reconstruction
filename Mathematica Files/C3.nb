          ",", 
         RowBox[{"attempt", "++"}], ",", 
         RowBox[{"(*", 
          RowBox[{
          "Generate", " ", "a", " ", "random", " ", "initial", " ", "guess"}],
           "*)"}], 
         RowBox[{
          RowBox[{"initialGuess", "=", 
           RowBox[{"{", 
            RowBox[{"0.05", ",", " ", "0.15", ",", " ", "0.25"}], "}"}]}], 
          ";", "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{"Run", " ", "Adam", " ", "optimizer"}], "*)"}], 
          RowBox[{"newSolution", "=", 
           RowBox[{"adamSolve", "[", 
            RowBox[{
            "equations", ",", "variables", ",", "initialGuess", ",", 
             "\[Alpha]", ",", "\[Beta]1", ",", "\[Beta]2", ",", 
             "\[CurlyEpsilon]", ",", "maxIterations", ",", "tolerance"}], 
            "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
           "Extract", " ", "numerical", " ", "values", " ", "from", " ", 
            "the", " ", "solution"}], "*)"}], 
          RowBox[{"solutionValues", "=", 
           RowBox[{"variables", "/.", " ", "newSolution"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
