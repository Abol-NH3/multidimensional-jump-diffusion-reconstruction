    RowBox[{
    "M211Coeffs", ",", "M212Coeffs", ",", "M213Coeffs", ",", " ", 
     "M222Coeffs", ",", " ", "M223Coeffs", ",", " ", "M233Coeffs"}], "}"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"equations2", "=", 
   RowBox[{"Select", "[", 
    RowBox[{
     RowBox[{"buildEquations", "[", 
      RowBox[{"MExprs2", ",", "monomials", ",", "targetCoeffs2"}], "]"}], ",", 
     RowBox[{
      RowBox[{"#", "=!=", "True"}], "&"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"equations2", "=", 
   RowBox[{"Select", "[", 
    RowBox[{"equations2", ",", 
     RowBox[{
      RowBox[{"#", "=!=", "False"}], "&"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"terms2", "=", 
   RowBox[{
    RowBox[{"Select", "[", 
     RowBox[{"equations2", ",", 
      RowBox[{
       RowBox[{"#", "=!=", "True"}], "&"}]}], "]"}], "/.", " ", 
    RowBox[{"Equal", "->", 
     RowBox[{"(", "Subtract", ")"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"vars2", "=", 
   RowBox[{"{", 
    RowBox[{"g11a", ",", "g22a", ",", " ", "g33a"}], " ", "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"constraints2", "=", 
   RowBox[{"Thread", "[", 
    RowBox[{"vars2", ">", "0"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"objective2", "=", 
   RowBox[{"Total", "[", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"#", "^", "2"}], "&"}], "/@", 
      RowBox[{"(", 
       RowBox[{"equations2", "/.", " ", 
        RowBox[{"Equal", "->", "Subtract"}]}], ")"}]}], ")"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"result2", "=", 
  RowBox[{"NMinimize", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"objective2", ",", "constraints2"}], "}"}], ",", "vars2"}], 
   "]"}]}]}], "Input",
